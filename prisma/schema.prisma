generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String   @id
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model DailyWork {
  id       String   @id
  userId   String
  date     DateTime @db.Date
  duration Int
  User     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id          String      @id
  email       String      @unique
  displayName String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  avatarUrl   String?
  bio         String?
  role        Role        @default(USER)
  Account     Account[]
  DailyWork   DailyWork[]
}

enum Role {
  USER
  ADMIN
}
